<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- React Refresh Hook for Local Development HMR -->
    <script type="module">
      import { injectIntoGlobalHook } from "/@react-refresh";
      injectIntoGlobalHook(window);
      window.$RefreshReg$ = () => {};
      window.$RefreshSig$ = () => (type) => type;
    </script>

    <!-- Dev Server Client -->
    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="same-origin" />
    <link rel="icon" href="/favicon.ico" />

    <!-- URL Parameter Cleanup Script -->
    <script>
      (function () {
        try {
          var url = new URL(location.href);
          // Checks and removes a specific tracking or session token if present
          if (url.searchParams.has('sessionToken')) {
            url.searchParams.delete('sessionToken');
            history.replaceState(null, '', url.toString());
          }
        } catch (error) {
          console.error("URL manipulation failed:", error);
        }
      })();
    </script>

    <title>Web Application</title>
